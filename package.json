{
  "name": "alpha-orion-root",
  "private": true,
  "version": "1.0.0",
  "description": "Root for Alpha-Orion monorepo, deployed on Google Cloud",
  "scripts": {
    "build": "cd backend-services/services/user-api-service && npm install",
    "start": "node backend-services/services/user-api-service/src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "@opentelemetry/exporter-cloud-trace": "npm:@google-cloud/opentelemetry-cloud-trace-exporter@^1.2.0"
  }
}
