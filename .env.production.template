# 📦 PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# Alpha-Orion Flash Loan Arbitrage Engine
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.production.template .env.production
# 2. Fill in all values marked with <YOUR_...>
# 3. Never commit .env.production to Git (already in .gitignore)
# 4. Store sensitive values in Google Secret Manager

# ============================================================================
# GOOGLE CLOUD CONFIGURATION
# ============================================================================

PROJECT_ID=alpha-orion
REGION=us-central1
ENVIRONMENT=production

# ============================================================================
# BLOCKCHAIN RPC ENDPOINTS (Get from Infura, Alchemy, QuickNode)
# ============================================================================

# Ethereum Mainnet
ETHEREUM_RPC_URL=<YOUR_ETHEREUM_RPC_URL>
# Example: https://eth-mainnet.alchemyapi.io/v2/YOUR-API-KEY

# Polygon
POLYGON_RPC_URL=<YOUR_POLYGON_RPC_URL>
# Example: https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# Arbitrum
ARBITRUM_RPC_URL=<YOUR_ARBITRUM_RPC_URL>
# Example: https://arb-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# Optimism
OPTIMISM_RPC_URL=<YOUR_OPTIMISM_RPC_URL>
# Example: https://opt-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# BSC (Binance Smart Chain)
BSC_RPC_URL=<YOUR_BSC_RPC_URL>
# Example: https://bsc-mainnet.nodereal.io/v1/YOUR-API-KEY

# Avalanche
AVALANCHE_RPC_URL=<YOUR_AVALANCHE_RPC_URL>
# Example: https://api.avax.network/ext/bc/C/rpc

# Base
BASE_RPC_URL=<YOUR_BASE_RPC_URL>
# Example: https://base-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# zkSync Era
ZKSYNC_RPC_URL=<YOUR_ZKSYNC_RPC_URL>
# Example: https://mainnet.era.zksync.io

# ============================================================================
# EXECUTION CONFIGURATION
# ============================================================================

# Private key for transaction signing (NEVER commit this!)
EXECUTOR_PRIVATE_KEY=<YOUR_PRIVATE_KEY>
# Example: 0x1234567890abcdef... (64 hex characters)

# Executor contract addresses (deployed flash loan executors)
EXECUTOR_CONTRACT_ETHEREUM=<YOUR_ETHEREUM_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_POLYGON=<YOUR_POLYGON_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_ARBITRUM=<YOUR_ARBITRUM_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_OPTIMISM=<YOUR_OPTIMISM_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_BSC=<YOUR_BSC_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_AVALANCHE=<YOUR_AVALANCHE_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_BASE=<YOUR_BASE_EXECUTOR_CONTRACT>
EXECUTOR_CONTRACT_ZKSYNC=<YOUR_ZKSYNC_EXECUTOR_CONTRACT>

# ============================================================================
# GAS & EXECUTION SETTINGS
# ============================================================================

# Maximum gas price in gwei
MAX_GAS_PRICE_GWE I=500

# Gas competitive multiplier (bid this much % above competitors)
GAS_COMPETITIVE_MULTIPLIER=1.1

# Execution latency target (milliseconds)
TARGET_LATENCY_MS=50

# ============================================================================
# MEV PROTECTION
# ============================================================================

# Enable Flashbots
FLASHBOTS_ENABLED=true
FLASHBOTS_RPC=https://rpc.flashbots.net

# Enable MEV-Blocker
MEV_BLOCKER_ENABLED=true
MEV_BLOCKER_RPC=https://rpc.mevblocker.io

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# VaR confidence level (0.999 = 99.9%)
VAR_CONFIDENCE=0.999

# Maximum portfolio drawdown (5%)
MAX_DRAWDOWN=0.05

# Maximum daily loss (10%)
MAX_DAILY_LOSS=0.10

# Maximum consecutive losses before circuit breaker
MAX_CONSECUTIVE_LOSSES=5

# Maximum position size (5% of portfolio)
MAX_POSITION_SIZE=0.05

# ============================================================================
# FLASH LOAN PROVIDERS
# ============================================================================

# Aave V3 Pool Addresses
AAVE_V3_POOL_ETHEREUM=0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2
AAVE_V3_POOL_POLYGON=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_V3_POOL_ARBITRUM=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_V3_POOL_OPTIMISM=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_V3_POOL_AVALANCHE=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_V3_POOL_BASE=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5

# ============================================================================
# API KEYS
# ============================================================================

# 1inch API Key (get from https://portal.1inch.dev)
ONEINCH_API_KEY=<YOUR_1INCH_API_KEY>

# Pimlico API Key (for ERC-4337 gasless transactions)
PIMLICO_API_KEY=pim_TDJjCjeAJdArjep3usKXTu

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# AlloyDB connection
DB_HOST=<YOUR_ALLOYDB_HOST>
DB_PORT=5432
DB_NAME=alpha_orion
DB_USER=postgres
DB_PASSWORD=<YOUR_DB_PASSWORD>

# Redis connection
REDIS_HOST=<YOUR_REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Google Cloud Monitoring
ENABLE_CLOUD_MONITORING=true

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# SLO targets
TARGET_UPTIME_PCT=99.95
TARGET_P99_LATENCY_MS=100
TARGET_ERROR_RATE_PCT=0.1

# ============================================================================
# COMPLIANCE
# ============================================================================

# Enable KYC/AML checks
KYC_REQUIRED=true
AML_THRESHOLD_USD=10000

# Enable sanctions screening
SANCTIONS_CHECK_ENABLED=true

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================

# Minimum profit threshold (USD)
MIN_PROFIT_USD=50

# Minimum spread for cross-DEX arbitrage (0.05%)
MIN_SPREAD_PERCENT=0.0005

# Statistical arbitrage z-score threshold
ZSCORE_THRESHOLD=2.0

# ============================================================================
# SCALING & PERFORMANCE
# ============================================================================

# Connection pool size
CONNECTION_POOL_SIZE=100
CONNECTION_PER_HOST=20

# Max concurrent opportunities to process
MAX_CONCURRENT_OPS=10

# Opportunity scanning interval (milliseconds)
SCAN_INTERVAL_MS=1000

# ============================================================================
# SECURITY
# ============================================================================

# Enable emergency circuit breaker
EMERGENCY_CIRCUIT_BREAKER=true

# Withdrawal wallet (for profit withdrawals, separate from executor)
WITHDRAWAL_WALLET_ADDRESS=<YOUR_WITHDRAWAL_WALLET>
WITHDRAWAL_PRIVATE_KEY=<YOUR_WITHDRAWAL_PRIVATE_KEY>

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable specific strategies
ENABLE_CROSS_EXCHANGE_ARB=true
ENABLE_TRIANGULAR_ARB=true
ENABLE_STATISTICAL_ARB=true  
ENABLE_FLASH_LOAN_ARB=true
ENABLE_DELTA_NEUTRAL=true

# Enable specific chains
ENABLE_ETHEREUM=true
ENABLE_POLYGON=true
ENABLE_ARBITRUM=true
ENABLE_OPTIMISM=true
ENABLE_BSC=true
ENABLE_AVALANCHE=true
ENABLE_BASE=true
ENABLE_ZKSYNC=true

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Email alerts
ALERT_EMAIL=<YOUR_EMAIL>

# Slack webhook (optional)
SLACK_WEBHOOK_URL=<YOUR_SLACK_WEBHOOK>

# PagerDuty integration key (optional)
PAGERDUTY_INTEGRATION_KEY=<YOUR_PAGERDUTY_KEY>

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================

# Set to false for production!
DEBUG_MODE=false
DRY_RUN=false

# ============================================================================
# NOTES
# ============================================================================
# 
# Security Best Practices:
# 1. Never commit this file with real values
# 2. Store all secrets in Google Secret Manager
# 3. Rotate private keys monthly
# 4. Use separate wallets for execution vs withdrawals
# 5. Enable MFA on all infrastructure accounts
# 
# Performance Tips:
# 1. Use premium RPC endpoints (paid plans)
# 2. Enable Redis caching for price feeds
# 3. Co-locate services in same region as exchanges
# 4. Use Cloud CDN for frontend
# 
# Cost Optimization:
# 1. Use spot instances where possible
# 2. Enable autoscaling
# 3. Monitor and optimize gas usage
# 4. Review cloud costs weekly
#
# Support:
# - Documentation: /docs folder
# - Monitoring: https://console.cloud.google.com/monitoring
# - Logs: https://console.cloud.google.com/logs
